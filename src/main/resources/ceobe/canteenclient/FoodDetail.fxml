<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="720.0" maxWidth="1000.0" minHeight="720.0" minWidth="1000.0" prefHeight="720.0" prefWidth="1000.0" styleClass="page-root" stylesheets="@../css/app.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ceobe.canteenclient.controller.FoodDetailController">

    <top>
        <HBox alignment="CENTER_LEFT" fillHeight="false" prefHeight="70.0" prefWidth="1000.0" spacing="12" styleClass="detail-top">
            <padding>
                <Insets bottom="12" left="20" right="20" top="18" />
            </padding>
            <Button onAction="#handleBack" styleClass="secondary-btn" text="← 返回" />
            <Label styleClass="page-title" text="食物详细信息" />
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" prefHeight="650.0" prefWidth="1000.0" styleClass="result-scroll">
            <content>
                <VBox spacing="18" styleClass="detail-wrap">
                    <padding>
                        <Insets bottom="20" left="20" right="20" top="20" />
                    </padding>

                    <HBox spacing="22" styleClass="detail-card">
                        <StackPane prefHeight="240.0" prefWidth="340.0" styleClass="image-frame">
                            <ImageView fx:id="foodImage" fitHeight="240.0" fitWidth="340.0" preserveRatio="true" />
                            <Label fx:id="imagePlaceholder" styleClass="image-placeholder" text="暂无图片" />
                        </StackPane>

                        <VBox prefWidth="560.0" spacing="10">
                            <Label fx:id="nameLabel" styleClass="detail-name" text="名称" />
                            <Label fx:id="locationLabel" text="地点：" />
                            <Label fx:id="priceLabel" text="价格：" />
                            <Label fx:id="scoreLabel" text="评分：" />
                            <Label fx:id="tagLabel" text="标签：" />
                        </VBox>
                    </HBox>

                    <VBox spacing="10" styleClass="detail-card">
                        <Label styleClass="section-title" text="介绍" />
                        <TextArea fx:id="introArea" editable="false" prefRowCount="10" styleClass="intro-area" wrapText="true" />
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
