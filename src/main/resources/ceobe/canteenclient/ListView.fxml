<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefWidth="1000.0" prefHeight="720.0"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ceobe.canteenclient.controller.ListController"
            style="-fx-background-color:#f6f9ff;">
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="12"
              style="-fx-background-color:#eef5ff; -fx-padding:14 18 14 18;">
            <children>
                <Label fx:id="titleLabel" text="列表" style="-fx-text-fill:#1f2d4d; -fx-font-size:18px; -fx-font-weight:bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="返回"
                        onAction="#handleBack"
                        style="-fx-background-color:#5c8dff; -fx-text-fill:white; -fx-background-radius:14; -fx-border-radius:14; -fx-padding:8 18 8 18;"/>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" pannable="true"
                    style="-fx-background:#f6f9ff; -fx-border-color:transparent;">
            <content>
                <TilePane fx:id="cardPane"
                          prefWidth="1000.0"
                          hgap="16.0" vgap="16.0"
                          style="-fx-background-color:#f6f9ff;"
                          prefColumns="2"/>
            </content>
        </ScrollPane>
    </center>
</BorderPane>