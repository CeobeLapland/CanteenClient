<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<BorderPane maxHeight="720.0" maxWidth="1000.0" minHeight="720.0" minWidth="1000.0" prefHeight="720.0" prefWidth="1000.0" stylesheets="@../css/app.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <top>
      <HBox alignment="CENTER" maxHeight="40.0" maxWidth="1000.0" minHeight="40.0" minWidth="1000.0" prefHeight="40.0" prefWidth="1000.0" spacing="200.0" BorderPane.alignment="CENTER">
         <children>
            <Button maxHeight="40.0" maxWidth="200.0" minHeight="40.0" minWidth="200.0" mnemonicParsing="false" onAction="#showRecipeListPanel" prefHeight="40.0" prefWidth="200.0" styleClass="secondary-btn" text="食谱" />
            <Button maxHeight="40.0" maxWidth="200.0" minHeight="40.0" minWidth="200.0" mnemonicParsing="false" onAction="#showCookingPanel" prefHeight="40.0" prefWidth="200.0" styleClass="secondary-btn" text="做菜" />
         </children>
      </HBox>
   </top>
   <center>
      <StackPane fx:id="cookContentPane" prefHeight="680.0" prefWidth="1000.0" BorderPane.alignment="CENTER" />
   </center>
</BorderPane>
