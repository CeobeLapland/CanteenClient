<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1000.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ceobe.canteenclient.controller.EatWhatController"
            style="-fx-background-color: linear-gradient(to bottom right, #EAF4FF, #F8FBFF);">

    <left>
        <VBox spacing="14" prefWidth="650.0" BorderPane.alignment="CENTER"
              style="-fx-padding: 20;">
            <StackPane alignment="CENTER"
                       style="-fx-background-color: rgba(255,255,255,0.82);
                              -fx-background-radius: 24;
                              -fx-border-color: #CFE4FF;
                              -fx-border-radius: 24;
                              -fx-border-width: 1;">
                <Canvas fx:id="wheelCanvas" width="440.0" height="440.0"
                        onMouseClicked="#handleWheelClick"/>
            </StackPane>

            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: rgba(255,255,255,0.72);
                         -fx-background-radius: 18;
                         -fx-padding: 12 14 12 14;
                         -fx-border-color: #D7E8FF;
                         -fx-border-radius: 18;">
                <Button fx:id="drawButton" text="抽取" onAction="#handleDraw"
                        prefWidth="120.0"
                        style="-fx-background-color: linear-gradient(to bottom, #2F80ED, #6AAEFF);
                               -fx-text-fill: white;
                               -fx-background-radius: 16;
                               -fx-font-size: 15px;
                               -fx-font-weight: bold;"/>
                <Label text="分块数量"
                       style="-fx-text-fill: #24507A; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Spinner fx:id="sectorSpinner" prefWidth="105.0"/>
            </HBox>

            <VBox spacing="8"
                  style="-fx-background-color: rgba(255,255,255,0.72);
                         -fx-background-radius: 18;
                         -fx-padding: 12 14 14 14;
                         -fx-border-color: #D7E8FF;
                         -fx-border-radius: 18;">
                <Label text="结果预览"
                       style="-fx-text-fill: #24507A; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <TextArea fx:id="resultPreviewArea" editable="false" wrapText="true"
                          prefHeight="180.0"
                          style="-fx-control-inner-background: #F7FBFF;
                                 -fx-background-radius: 14;
                                 -fx-border-radius: 14;
                                 -fx-border-color: #D7E8FF;
                                 -fx-font-size: 13px;"/>
            </VBox>
        </VBox>
    </left>

    <right>
        <VBox spacing="12" prefWidth="320.0" BorderPane.alignment="CENTER"
              style="-fx-padding: 20;
                     -fx-background-color: rgba(255,255,255,0.40);">
            <Label text="食物 Tags"
                   style="-fx-text-fill: #24507A; -fx-font-size: 20px; -fx-font-weight: bold;"/>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        prefHeight="580.0"
                        style="-fx-background-color: transparent;
                               -fx-background: transparent;
                               -fx-border-color: transparent;">
                <content>
                    <FlowPane fx:id="tagFlowPane" hgap="10" vgap="10"
                              prefWrapLength="260.0"
                              style="-fx-padding: 10;"/>
                </content>
            </ScrollPane>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="confirmButton" text="确定" onAction="#handleConfirmTags"
                        prefWidth="90.0"
                        style="-fx-background-color: linear-gradient(to bottom, #2F80ED, #6AAEFF);
                               -fx-text-fill: white;
                               -fx-background-radius: 16;
                               -fx-font-size: 14px;
                               -fx-font-weight: bold;"/>
                <Button fx:id="clearButton" text="清空" onAction="#handleClearTags"
                        prefWidth="90.0"
                        style="-fx-background-color: #D9E9FF;
                               -fx-text-fill: #24507A;
                               -fx-background-radius: 16;
                               -fx-font-size: 14px;
                               -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </right>

</BorderPane>