<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1000.0" styleClass="page-root" stylesheets="@../css/app.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ceobe.canteenclient.controller.FoodController">

    <left>
        <VBox maxHeight="720.0" maxWidth="240.0" minHeight="720.0" minWidth="240.0" prefHeight="720.0" prefWidth="240.0" spacing="12" styleClass="sidebar">
            <padding>
                <Insets bottom="20" left="16" right="16" top="20" />
            </padding>

            <Label styleClass="sidebar-title" text="可多选 Tag 筛选" />
         <ScrollPane fx:id="tagScrollPane" prefHeight="550.0" prefWidth="200.0">
            <content>
               <FlowPane fx:id="tagFlowPane" prefHeight="550.0" prefWidth="180.0" />
            </content>
         </ScrollPane>
            <Button onAction="#clearTags" styleClass="secondary-btn" text="清空 Tag 选择" />
        </VBox>
    </left>

    <center>
        <VBox prefHeight="720.0" prefWidth="760.0" spacing="14" styleClass="food-center">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <TextField fx:id="searchField" promptText="搜索食物名称 / 地点 / 窗口 / 介绍" styleClass="search-field" />

            <HBox spacing="10">
                <ComboBox fx:id="campusBox" prefWidth="150.0" promptText="校区" styleClass="filter-box" />
                <ComboBox fx:id="canteenBox" prefWidth="150.0" promptText="食堂" styleClass="filter-box" />
                <ComboBox fx:id="floorBox" prefWidth="150.0" promptText="楼层" styleClass="filter-box" />
                <ComboBox fx:id="windowBox" prefWidth="150.0" promptText="窗口" styleClass="filter-box" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleSearch" styleClass="primary-btn" text="查找" />
            </HBox>

            <ScrollPane fitToWidth="true" pannable="true" styleClass="result-scroll">
                <content>
                    <VBox fx:id="foodListBox" spacing="12" styleClass="food-list" />
                </content>
            </ScrollPane>

            <HBox fx:id="pageBar" alignment="CENTER_RIGHT" spacing="6" styleClass="page-bar" />
        </VBox>
    </center>
</BorderPane>
