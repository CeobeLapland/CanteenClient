<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="1000.0" prefHeight="720.0"
            stylesheets="@../css/app.css"
            styleClass="page-root"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ceobe.canteenclient.controller.ChannelController">

    <left>
        <VBox prefWidth="180.0" spacing="12" styleClass="sidebar">
            <padding>
                <Insets top="18" right="14" bottom="18" left="14"/>
            </padding>

            <Label text="帖子类型" styleClass="sidebar-title"/>

            <VBox fx:id="typeButtonBox" spacing="8" prefWidth="150.0"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="发帖" onAction="#handleCreatePost" styleClass="primary-btn" maxWidth="1.7976931348623157E308"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="12" styleClass="food-center">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>

            <StackPane prefHeight="110.0" styleClass="detail-card">
                <Label text="公告 / 热门 区域（待接入）" styleClass="page-title"/>
            </StackPane>

            <HBox spacing="10">
                <TextField fx:id="searchField"
                           promptText="搜索帖子内容 / 标题 / 作者"
                           styleClass="search-field"
                           HBox.hgrow="ALWAYS"/>
                <Button text="搜索" onAction="#handleSearch" styleClass="primary-btn"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="排序：" styleClass="section-title"/>
                <Button fx:id="sortTimeBtn" text="按时间" onAction="#sortByTime" styleClass="page-btn"/>
                <Button fx:id="sortViewsBtn" text="按浏览量" onAction="#sortByViews" styleClass="page-btn"/>
                <Button fx:id="sortLikesBtn" text="按点赞量" onAction="#sortByLikes" styleClass="page-btn"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="ascBtn" text="升序" onAction="#sortAscending" styleClass="page-btn"/>
                <Button fx:id="descBtn" text="降序" onAction="#sortDescending" styleClass="page-btn"/>
            </HBox>

            <ScrollPane fitToWidth="true" pannable="true" styleClass="result-scroll">
                <content>
                    <VBox fx:id="postListBox" spacing="12" styleClass="food-list"/>
                </content>
            </ScrollPane>

            <HBox fx:id="pageBar" spacing="6" alignment="CENTER_RIGHT" styleClass="page-bar"/>
        </VBox>
    </center>
</BorderPane>