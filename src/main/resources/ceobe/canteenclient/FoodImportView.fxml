<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane maxHeight="720.0" maxWidth="1000.0" minHeight="720.0" minWidth="1000.0" prefHeight="720.0" prefWidth="1000.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25">
   <content>
      <VBox maxWidth="1000.0" prefWidth="1000.0">
         <children>
            <BorderPane maxHeight="720.0" maxWidth="1000.0" prefHeight="720.0" prefWidth="1000.0" style="-fx-background-color: linear-gradient(to bottom right, #f4f9ff, #e9f3ff);">
               <top>
                  <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: rgba(255,255,255,0.78); -fx-background-radius: 0 0 18 18; -fx-padding: 14 18 14 18;">
                     <children>
                        <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1f4f8a;" text="FoodItem 批量导入" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="backButton" onAction="#handleBack" style="-fx-background-color: #5aa7ff; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 8 18 8 18;" text="返回" />
                     </children>
                  </HBox>
               </top>
               <center>
                  <VBox spacing="14">
                     <children>
                        <HBox spacing="14" VBox.vgrow="ALWAYS">
                           <children>
                              <ScrollPane fx:id="scrollPane" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent; -fx-padding: 0;" vbarPolicy="AS_NEEDED" HBox.hgrow="ALWAYS">
                                 <content>
                                    <VBox fx:id="formBox" fillWidth="true" spacing="12" style="-fx-background-color: transparent;" />
                                 </content>
                              </ScrollPane>
                              <VBox alignment="TOP_CENTER" spacing="12" style="-fx-background-color: rgba(255,255,255,0.72); -fx-background-radius: 18; -fx-padding: 14; -fx-min-width: 110;">
                                 <children>
                                    <Button onAction="#handleAdd" prefHeight="46" prefWidth="70" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-background-color: #5aa7ff; -fx-text-fill: white; -fx-background-radius: 14;" text="+" />
                                    <Button onAction="#handleRemove" prefHeight="46" prefWidth="70" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-background-color: #8bbff6; -fx-text-fill: white; -fx-background-radius: 14;" text="-" />
                                    <Button onAction="#handleClear" prefHeight="46" prefWidth="70" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-background-color: #d7e9ff; -fx-text-fill: #1f4f8a; -fx-background-radius: 14; -fx-border-color: #b9d7fb; -fx-border-radius: 14;" text="CLEAR" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: rgba(255,255,255,0.72); -fx-background-radius: 18; -fx-padding: 16;">
                           <children>
                              <StackPane fx:id="dropZone" onMouseClicked="#handleChooseExcel" prefHeight="132" prefWidth="690" style="-fx-background-color: #f8fbff; -fx-border-color: #95bfe9; -fx-border-width: 2; -fx-border-style: dashed; -fx-border-radius: 18; -fx-background-radius: 18;" HBox.hgrow="ALWAYS">
                                 <children>
                                    <VBox alignment="CENTER" spacing="8">
                                       <children>
                                          <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1f4f8a;" text="拖拽 Excel 文件到这里" />
                                          <Label style="-fx-font-size: 13px; -fx-text-fill: #5c7da6;" text="或点击此区域选择文件" />
                                          <Label fx:id="excelFileLabel" style="-fx-font-size: 12px; -fx-text-fill: #2f5d8a;" text="未选择文件" wrapText="true" />
                                       </children>
                                    </VBox>
                                 </children>
                              </StackPane>
                              <Button onAction="#handleConfirm" prefHeight="132" prefWidth="190" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-background-color: #4f9ef5; -fx-text-fill: white; -fx-background-radius: 20;" text="确定" />
                           </children>
                        </HBox>
                        <Label fx:id="statusLabel" style="-fx-font-size: 12px; -fx-text-fill: #54789a;" text="提示：手动填写后点击“确定”才会校验并导入；Excel 也会在点击“确定”后读取。" wrapText="true" />
                     </children>
                  </VBox>
               </center>
            </BorderPane>
            <BorderPane maxWidth="1000.0" prefHeight="400.0" prefWidth="1000.0" />
         </children>
      </VBox>
   </content>
</ScrollPane>
