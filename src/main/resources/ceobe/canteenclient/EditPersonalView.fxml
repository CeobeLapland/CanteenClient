<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane prefWidth="1000.0" prefHeight="720.0"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ceobe.canteenclient.controller.EditPersonalController"
            style="-fx-background-color:#f6f9ff;">
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="12"
              style="-fx-background-color:#eef5ff; -fx-padding:14 18 14 18;">
            <children>
                <Label text="修改个人资料" style="-fx-text-fill:#1f2d4d; -fx-font-size:18px; -fx-font-weight:bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="18.0" style="-fx-background-color:#f6f9ff;">
            <children>

                <HBox spacing="18.0" alignment="CENTER_LEFT">
                    <children>
                        <StackPane fx:id="avatarPickPane"
                                   prefWidth="120.0" prefHeight="120.0"
                                   onMouseClicked="#handleChooseAvatar"
                                   style="-fx-background-color:white; -fx-background-radius:20; -fx-border-radius:20; -fx-border-color:#cfe0ff; -fx-cursor:hand;">
                            <children>
                                <ImageView fx:id="avatarPreview"
                                           fitWidth="120.0" fitHeight="120.0"
                                           preserveRatio="true"
                                           smooth="true"/>
                                <Label fx:id="avatarPickHint"
                                       text="点击选择头像"
                                       style="-fx-text-fill:#6f8fd9; -fx-font-size:14px; -fx-font-weight:bold;"/>
                            </children>
                        </StackPane>

                        <VBox spacing="8.0">
                            <children>
                                <Label text="头像区域支持 png / jpg / jpeg 文件" style="-fx-text-fill:#6b7a99;"/>
                                <Label text="点击头像框即可更换头像" style="-fx-text-fill:#6b7a99;"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="14" style="-fx-background-color:white; -fx-background-radius:20; -fx-border-radius:20; -fx-border-color:#dbe7ff; -fx-padding:20;">
                    <children>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <children>
                                <Label text="名称" prefWidth="80" style="-fx-text-fill:#6b7a99;"/>
                                <TextField fx:id="nameField" promptText="请输入名称" prefWidth="320"/>
                            </children>
                        </HBox>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <children>
                                <Label text="UID" prefWidth="80" style="-fx-text-fill:#6b7a99;"/>
                                <TextField fx:id="uidField" promptText="请输入UID" prefWidth="320"/>
                            </children>
                        </HBox>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <children>
                                <Label text="加入时间" prefWidth="80" style="-fx-text-fill:#6b7a99;"/>
                                <TextField fx:id="joinTimeField" promptText="例如 2025-01-01" prefWidth="320"/>
                            </children>
                        </HBox>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <children>
                                <Label text="权限" prefWidth="80" style="-fx-text-fill:#6b7a99;"/>
                                <TextField fx:id="permissionField" promptText="例如 普通用户 / 管理员" prefWidth="320"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <children>
                        <Button text="取消"
                                onAction="#handleCancel"
                                style="-fx-background-color:#dfe9ff; -fx-text-fill:#1f2d4d; -fx-background-radius:14; -fx-border-radius:14; -fx-padding:8 18 8 18;"/>
                        <Button text="确定"
                                onAction="#handleConfirm"
                                style="-fx-background-color:#5c8dff; -fx-text-fill:white; -fx-background-radius:14; -fx-border-radius:14; -fx-padding:8 18 8 18;"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>